@using EduFlow.ViewModels.Dashboard
@model InstructorDashboardVM

@{
    ViewData["Title"] = "Instructor Dashboard";
}

<div class="container mt-4">

    <h2 class="mb-4">
        <i class="bi bi-speedometer2"></i>
        Instructor Dashboard
    </h2>

    <div class="row g-3 mb-5">

        <div class="col-md-2">
            <div class="card shadow-sm border-0 text-center">
                <div class="card-body">
                    <h6 class="text-muted">Courses</h6>
                    <h2 class="text-primary">@Model.CoursesCount</h2>
                </div>
            </div>
        </div>

        <div class="col-md-2">
            <div class="card shadow-sm border-0 text-center">
                <div class="card-body">
                    <h6 class="text-muted">Students</h6>
                    <h2 class="text-success">@Model.StudentsCount</h2>
                </div>
            </div>
        </div>

        <div class="col-md-2">
            <div class="card shadow-sm border-0 text-center">
                <div class="card-body">
                    <h6 class="text-muted">Sections</h6>
                    <h2 class="text-warning">@Model.SectionsCount</h2>
                </div>
            </div>
        </div>

        <div class="col-md-2">
            <div class="card shadow-sm border-0 text-center">
                <div class="card-body">
                    <h6 class="text-muted">Lessons</h6>
                    <h2 class="text-info">@Model.LessonsCount</h2>
                </div>
            </div>
        </div>

        <div class="col-md-2">
            <div class="card shadow-sm border-0 text-center">
                <div class="card-body">
                    <h6 class="text-muted">Reviews</h6>
                    <h2 class="text-danger">@Model.ReviewsCount</h2>
                </div>
            </div>
        </div>

    </div>

    <div class="card shadow-sm border-0">

        <div class="card-header bg-white">
            <h4 class="mb-0">
                My Courses
            </h4>
        </div>

        <div class="card-body">

            @if (Model.Courses.Any())
            {
                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead class="table-light">

                            <tr>
                                <th>Course</th>
                                <th>Students</th>
                                <th>Sections</th>
                                <th>Lessons</th>
                                <th>Rating</th>
                                <th></th>
                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var course in Model.Courses)
                            {
                                <tr>

                                    <td>
                                        <strong>@course.Title</strong>
                                    </td>

                                    <td>
                                        <span class="badge bg-success">
                                            @course.StudentsCount
                                        </span>
                                    </td>

                                    <td>
                                        <span class="badge bg-warning text-dark">
                                            @course.SectionsCount
                                        </span>
                                    </td>

                                    <td>
                                        <span class="badge bg-info text-dark">
                                            @course.LessonsCount
                                        </span>
                                    </td>

                                    <td>

                                        @if (course.AverageRating == 0)
                                        {
                                            <span class="text-muted">
                                                No Reviews
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-warning">
                                                ★
                                            </span>

                                            @course.AverageRating.ToString("0.0")
                                        }

                                    </td>

                                    <td>

                                        <a asp-controller="Courses"
                                           asp-action="Details"
                                           asp-route-id="@course.Id"
                                           class="btn btn-outline-primary btn-sm">

                                            Manage

                                        </a>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">

                    You haven't created any courses yet.

                </div>
            }

        </div>

    </div>

</div>