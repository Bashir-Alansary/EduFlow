@using EduFlow.ViewModels.Courses
@model CourseDetailsVM

<div class="container mt-4">

    <!-- Course Image -->
    <div class="mb-3">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="Course Image" class="img-fluid rounded" style="max-height: 300px;" />
        }
        else
        {
            <div class="alert alert-warning">
                No image available
            </div>
        }
    </div>

    <!-- Course Info -->
    <div class="mb-3">
        <h2>@Model.Title</h2>
        <p>@Model.Description</p>

        <ul class="list-group mb-3">
            <li class="list-group-item"><strong>Category:</strong> @Model.CategoryName</li>
            <li class="list-group-item"><strong>Instructor:</strong> @Model.InstructorName</li>
            <li class="list-group-item"><strong>Price:</strong> @Model.Price</li>
            <li class="list-group-item"><strong>Level:</strong> @Model.Level</li>
            <li class="list-group-item"><strong>Students:</strong> @Model.StudentsCount</li>
            <li class="list-group-item"><strong>Sections:</strong> @Model.SectionsCount</li>
        </ul>
    </div>

    <hr />

    <!-- Enrollment Section -->
    <div>
        @if (Model.IsEnrolled)
        {
            <button class="btn btn-secondary" disabled>
                Already Enrolled
            </button>
        }
        else
        {
            <form asp-action="Enroll" method="post">
                <input type="hidden" name="courseId" value="@Model.Id" />

                <button type="submit" class="btn btn-success">
                    Enroll Now
                </button>
            </form>
        }
    </div>

    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Student"))
    {
        @if (Model.IsInWishlist)
        {
            <form asp-action="RemoveFromWishlist" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="courseId"
                       value="@Model.Id" />

                <button class="btn btn-outline-danger">
                    Remove From Wishlist
                </button>
            </form>
        }
        else
        {
            <form asp-action="AddToWishlist" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="courseId"
                       value="@Model.Id" />

                <button class="btn btn-outline-primary">
                    Add To Wishlist
                </button>
            </form>
        }
    }

</div>