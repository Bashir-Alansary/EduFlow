@model List<EduFlow.Entities.Course>

<h2>Courses</h2>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Image</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var course in Model)
        {
            <tr>
                <td>@course.Title</td>
                <td>@course.Description</td>
                <td>
                    @if (!string.IsNullOrEmpty(course.ImageUrl))
                    {
                        <img src="@course.ImageUrl" alt="@course.Title" width="100" />
                    }
                    else
                    {
                        <span>No image</span>
                    }
            </tr>
        }
    </tbody>
</table>